{
  "name": "task-dashboard",
  "version": "0.1.0",
  "description": "Every task in your vault, in one panel. Check them off and it writes back to the note.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "esbuild src/main.js --bundle --format=esm --outfile=dist/main.js",
    "dev": "esbuild src/main.js --bundle --format=esm --outfile=dist/main.js --watch",
    "test": "node --test"
  },
  "devDependencies": {
    "esbuild": "^0.23.0"
  }
}
